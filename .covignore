# Coverage exclusions — regex patterns matched against lines of the
# raw `go test -coverprofile` output, applied before the 100% gate
# by covgate (https://github.com/kfet/covgate).
#
# Convention: file-level patterns only. No line numbers, no
# per-function regexes — both rot on any nearby edit. Whole files,
# whole subpackages, whole generated bundles are fine.

# Entry-point shims: cmd/<binary>/main.go.
^github.com/kfet/poe-acp/cmd/[^/]+/main\.go:

# Per-package "unreachable.go" files (legacy — prefer excluding the
# file the code naturally lives in, or restructure to remove the
# unreachable branch entirely; see covgate README).
/unreachable\.go:
