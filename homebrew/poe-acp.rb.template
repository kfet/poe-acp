# This is a template for the kfet/homebrew-fir tap.
#
# Formula/poe-acp.rb in the tap is regenerated automatically by
# GoReleaser on every kfet/poe-acp tag push (see the brews: block
# in .goreleaser.yaml). This file is kept in the main repo purely as a
# reference — it is NOT the file Homebrew reads, and edits here do not
# affect users.
#
# Users install with:
#   brew install kfet/fir/poe-acp
#   (or: brew tap kfet/fir && brew install poe-acp)

class PoeAcpRelay < Formula
  desc "HTTP relay between Poe server bots and ACP-speaking agents"
  homepage "https://github.com/kfet/poe-acp"
  license "MIT"

  # GoReleaser replaces url, sha256, and version on each release.
  url "https://github.com/kfet/poe-acp/releases/download/v0.1.0/poe-acp-#{OS}-#{ARCH}"
  version "0.1.0"
  sha256 "PLACEHOLDER"

  def install
    bin.install Dir["poe-acp-*"].first => "poe-acp"
  end

  test do
    system bin/"poe-acp", "--version"
  end
end
